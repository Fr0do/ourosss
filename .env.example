# OuroSSS — copy to .env and fill in values

# AI providers (required for Hermes + Swarm agents)
ANTHROPIC_API_KEY=          # Claude models (Hermes primary, Claude Code)
OPENAI_API_KEY=             # Swarm codex agents (gpt-5.x series)
GEMINI_API_KEY=             # Swarm gemini agents (gemini-3.x series)

# Telegram bot (required)
TELEGRAM_TOKEN=
AUTHORIZED_USERS=              # comma-separated Telegram user IDs

# Notion integration (optional)
NOTION_SECRET=
NOTION_DB_ID=                  # Experiment Log DB
NOTION_RESEARCH_DB_ID=         # Research Log DB

# Telegram client API (for scripts/telegram/)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# GitHub (for auto-dev, /feature)
GITHUB_TOKEN=

# HuggingFace (dataset upload)
HF_TOKEN=

# Optional overrides
LOCAL_HOSTNAME=                # set to "kurkin-1" when running on remote
BOT_TMUX_SESSION=ouro
