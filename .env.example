# Required
TELEGRAM_TOKEN=
AUTHORIZED_USERS=

# Optional: Notion integration
NOTION_SECRET=
NOTION_DB_ID=

# Bot tmux session name
BOT_TMUX_SESSION=ouro

# Skip SSH when bot runs on target machine
LOCAL_HOSTNAME=

# Conda activation (set both for remote servers)
# CONDA_SETUP is the eval line from `conda init` output
CONDA_SETUP=
CONDA_ENV=

# HuggingFace cache
HF_HOME=
