# Ouroboros — copy to .env and fill in values

# Telegram bot (required)
TELEGRAM_TOKEN=
AUTHORIZED_USERS=              # comma-separated Telegram user IDs

# Notion integration (optional)
NOTION_SECRET=
NOTION_DB_ID=                  # Experiment Log DB
NOTION_RESEARCH_DB_ID=         # Research Log DB

# Telegram client API (for scripts/telegram/)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# GitHub (for auto-dev, /feature)
GITHUB_TOKEN=

# Optional overrides
LOCAL_HOSTNAME=                # set to "kurkin-1" when running on remote
BOT_TMUX_SESSION=ouro
