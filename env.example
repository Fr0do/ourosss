# Ouroboros — required environment variables
# Copy to .env and fill in values: cp env.example .env

# Telegram bot (required)
TELEGRAM_TOKEN=
AUTHORIZED_USERS=           # comma-separated Telegram user IDs

# GitHub (for auto-dev, issue creation, CI)
GITHUB_TOKEN=

# Optional overrides
LOCAL_HOSTNAME=             # set to "kurkin-1" when running on remote
BOT_TMUX_SESSION=ouro      # tmux session name for bot
GH_BIN=~/.local/bin/gh     # path to gh CLI binary
